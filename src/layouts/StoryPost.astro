---
import BaseLayout from "./BaseLayout.astro";
import ProgressBar from "../components/ProgressBar.astro";

interface Props {
  title: string;
  date: Date;
  description: string;
  readTime?: string;
  tags?: string[];
  image?: string;
  lastUpdated?: Date;
}

const { title, date, description, readTime, tags = [], image, lastUpdated } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedTime={date.toISOString()}
>
  <ProgressBar />

  {/* Hero */}
  <header class="flex min-h-[70vh] flex-col items-center justify-center px-6 text-center">
    <div class="flex items-center gap-3 text-sm text-[var(--color-text-tertiary)]">
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
          timeZone: "UTC",
        })}
      </time>
      {readTime && <span>&middot; {readTime}</span>}
    </div>
    {lastUpdated && (
      <p class="mt-2 text-xs text-[var(--color-text-tertiary)]">
        Last updated: <time datetime={lastUpdated.toISOString()}>
          {lastUpdated.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
            timeZone: "UTC",
          })}
        </time>
      </p>
    )}
    <h1
      class="mt-6 max-w-4xl text-4xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-5xl md:text-6xl"
    >
      {title}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-[var(--color-text-secondary)]">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="mt-6 flex gap-2">
          {tags.map((tag) => (
            <span class="rounded-full bg-[var(--color-surface-alt)] px-3 py-1 text-xs text-[var(--color-text-tertiary)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    {image && (
      <img
        src={image}
        alt={title}
        class="mt-10 w-full max-w-4xl rounded-2xl object-cover shadow-2xl"
        loading="eager"
      />
    )}
  </header>

  {/* Story content */}
  <div class="story-content">
    <slot />
  </div>

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description: description,
      datePublished: date.toISOString(),
      author: {
        "@type": "Person",
        name: "Murat Karslioglu",
        url: "https://muratkarslioglu.com",
      },
    })}
  />
</BaseLayout>

<style>
  .story-content :global(section) {
    padding: 5rem 1.5rem;
  }

  .story-content :global(.story-section-narrow) {
    max-width: 720px;
    margin: 0 auto;
  }

  .story-content :global(.story-section-wide) {
    max-width: 1024px;
    margin: 0 auto;
  }

  /* Typography for story content */
  .story-content :global(h2) {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
  }

  .story-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .story-content :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .story-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .story-content :global(ul),
  .story-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .story-content :global(ul) {
    list-style-type: disc;
  }

  .story-content :global(ol) {
    list-style-type: decimal;
  }

  .story-content :global(li) {
    margin-bottom: 0.375rem;
  }

  .story-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .story-content :global(a:hover) {
    text-decoration: underline;
  }

  .story-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--color-surface-alt);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }

  .story-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .story-content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .story-content :global(img) {
    border-radius: 0.75rem;
    margin: 2rem 0;
  }

  .story-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
