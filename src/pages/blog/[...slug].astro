---
import { getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import StoryPost from "../../layouts/StoryPost.astro";
import StorageEvolution from "../../components/StorageEvolution.astro";
import ProtocolEvolution from "../../components/ProtocolEvolution.astro";
import PosixEvolution from "../../components/PosixEvolution.astro";
import GoRustEvolution from "../../components/GoRustEvolution.astro";
import S3Evolution from "../../components/S3Evolution.astro";
import SDCEvolution from "../../components/SDCEvolution.astro";
import HashEvolution from "../../components/HashEvolution.astro";
import SIMDEvolution from "../../components/SIMDEvolution.astro";
import RebuildEvolution from "../../components/RebuildEvolution.astro";
import EDSFFEvolution from "../../components/EDSFFEvolution.astro";
import PCIeEvolution from "../../components/PCIeEvolution.astro";
import IOUringEvolution from "../../components/IOUringEvolution.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, description, readTime, tags, image, type, lastUpdated } = post.data;

const Layout = type === "story" ? StoryPost : BlogPost;
const showStorageEvolution = post.id === "storage-is-dead-long-live-data";
const showProtocolEvolution = post.id === "storage-protocols-ai-era";
const showPosixEvolution = post.id === "posix-pull-the-plug";
const showGoRustEvolution = post.id === "why-not-go-for-storage";
const showS3Evolution = post.id === "s3-api-holding-storage-back";
const showSDCEvolution = post.id === "silent-data-corruption-the-invisible-threat";
const showHashEvolution = post.id === "hashing-algorithms-the-next-five-years";
const showSIMDEvolution = post.id === "simd-mandatory-erasure-coding";
const showRebuildEvolution = post.id === "rebuild-time-crisis";
const showEDSFFEvolution = post.id === "edsff-e2-next-gen-drives";
const showPCIeEvolution = post.id === "pcie-lanes-numa-rust-storage";
const showIOUringEvolution = post.id === "io-uring-spdk-kernel-bypass";
---

<Layout
  title={title}
  date={date}
  description={description}
  readTime={readTime}
  tags={tags}
  image={image}
  lastUpdated={lastUpdated}
>
  <Content />
  {showStorageEvolution && (
    <StorageEvolution slot="right-sidebar" />
  )}
  {showProtocolEvolution && (
    <ProtocolEvolution slot="right-sidebar" />
  )}
  {showPosixEvolution && (
    <PosixEvolution slot="right-sidebar" />
  )}
  {showGoRustEvolution && (
    <GoRustEvolution slot="right-sidebar" />
  )}
  {showS3Evolution && (
    <S3Evolution slot="right-sidebar" />
  )}
  {showSDCEvolution && (
    <SDCEvolution slot="right-sidebar" />
  )}
  {showHashEvolution && (
    <HashEvolution slot="right-sidebar" />
  )}
  {showSIMDEvolution && (
    <SIMDEvolution slot="right-sidebar" />
  )}
  {showRebuildEvolution && (
    <RebuildEvolution slot="right-sidebar" />
  )}
  {showEDSFFEvolution && (
    <EDSFFEvolution slot="right-sidebar" />
  )}
  {showPCIeEvolution && (
    <PCIeEvolution slot="right-sidebar" />
  )}
  {showIOUringEvolution && (
    <IOUringEvolution slot="right-sidebar" />
  )}
</Layout>
