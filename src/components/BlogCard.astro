---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, date, description, readTime, tags } = post.data;
---

<article>
  <a
    href={`/blog/${post.id}`}
    class="group block rounded-2xl border border-[var(--color-border)]/50 p-6 transition-all duration-200 hover:border-[var(--color-border)] hover:shadow-sm"
  >
    <time
      datetime={date.toISOString()}
      class="text-xs text-[var(--color-text-tertiary)]"
    >
      {date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
        timeZone: "UTC",
      })}
    </time>
    <h3
      class="mt-2 text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors duration-200"
    >
      {title}
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
      {description}
    </p>
    <div class="mt-4 flex items-center gap-3">
      {
        readTime && (
          <span class="text-xs text-[var(--color-text-tertiary)]">
            {readTime}
          </span>
        )
      }
      {
        tags.length > 0 && (
          <div class="flex gap-2">
            {tags.map((tag) => (
              <span class="rounded-full bg-[var(--color-surface-alt)] px-2 py-0.5 text-xs text-[var(--color-text-tertiary)]">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>
