---
interface ArticlePreview {
  title: string;
  description: string;
}

interface Props {
  type: "front" | "back";
  issueDate?: string;
  featuredArticles?: ArticlePreview[];
}

const { type, issueDate, featuredArticles = [] } = Astro.props;

// issueDate is already formatted like "February 2026"
const formattedDate = issueDate || "";
---

<div class:list={["magazine-page"]} data-density="hard" data-page-role={type === "back" ? "back-cover" : undefined}>
  {
    type === "front" ? (
      <div class="cover cover-front">
        <div class="cover-header">
          <div class="cover-brand">THE</div>
          <div class="cover-title">MK</div>
          <div class="cover-brand">REVIEW</div>
        </div>
        <div class="cover-rule" />
        <div class="cover-date">{formattedDate}</div>
        <div class="cover-features">
          {featuredArticles.slice(0, 3).map((article, i) => (
            <div class="cover-feature">
              {i === 0 ? (
                <h2 class="cover-headline-main">{article.title}</h2>
              ) : (
                <h3 class="cover-headline">{article.title}</h3>
              )}
              {i === 0 && (
                <p class="cover-deck">{article.description}</p>
              )}
            </div>
          ))}
        </div>
        <div class="cover-footer">
          <span>muratkarslioglu.com</span>
        </div>
      </div>
    ) : (
      <div class="cover cover-back">
        <div class="back-content">
          <div class="back-logo">MK</div>
          <div class="back-tagline">
            Product, technology, and building things.
          </div>
          <div class="back-links">
            <div class="back-link">muratkarslioglu.com</div>
            <div class="back-link">@muratkarslioglu</div>
            <div class="back-link">github.com/muratkars</div>
          </div>
        </div>
      </div>
    )
  }
</div>

<style>
  .magazine-page {
    overflow: hidden;
  }

  .cover {
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  /* Front cover */
  .cover-front {
    background: #1a1a1a;
    color: white;
    padding: 2.5rem;
  }

  .cover-header {
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .cover-brand {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .cover-title {
    font-family: var(--font-sans);
    font-size: 4.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: white;
    margin: 0.125rem 0;
  }

  .cover-rule {
    height: 3px;
    background: #c0392b;
    margin: 1rem 0;
  }

  .cover-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .cover-features {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
  }

  .cover-feature {
    padding-left: 0.75rem;
    border-left: 2px solid #c0392b;
  }

  .cover-headline-main {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .cover-headline {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
  }

  .cover-deck {
    font-family: Georgia, serif;
    font-size: 0.75rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.25rem;
    line-height: 1.5;
  }

  .cover-footer {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Back cover */
  .cover-back {
    background: #1a1a1a;
    color: white;
    justify-content: center;
    align-items: center;
    padding: 2.5rem;
  }

  .back-content {
    text-align: center;
  }

  .back-logo {
    font-family: var(--font-sans);
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .back-tagline {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 2rem;
  }

  .back-links {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.02em;
  }
</style>
