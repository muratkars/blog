---
---

<aside class="hash-evolution hidden lg:block">
  <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
      Hash Algorithm Guide
    </p>

    <div class="svg-container">
      <svg viewBox="0 0 200 230" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">

        <!-- Stage 1: Why It Matters -->
        <g id="hash-stage-1" class="hash-stage active">
          <!-- Timeline of bad choices -->
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">Hash Decisions Haunt You</text>

          <line x1="30" y1="30" x2="170" y2="30" stroke="var(--color-border)" stroke-width="1" />

          <!-- ZFS -->
          <circle cx="45" cy="30" r="3" fill="#e74c3c" />
          <text x="45" y="45" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">ZFS</text>
          <text x="45" y="54" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">fletcher4</text>
          <text x="45" y="63" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2005</text>

          <!-- btrfs -->
          <circle cx="80" cy="30" r="3" fill="#e74c3c" />
          <text x="80" y="45" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">btrfs</text>
          <text x="80" y="54" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">CRC32C</text>
          <text x="80" y="63" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2007</text>

          <!-- S3 -->
          <circle cx="115" cy="30" r="3" fill="#e74c3c" />
          <text x="115" y="45" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">S3</text>
          <text x="115" y="54" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">MD5</text>
          <text x="115" y="63" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2006</text>

          <!-- MinIO -->
          <circle cx="150" cy="30" r="3" fill="var(--color-accent)" />
          <text x="150" y="45" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">MinIO</text>
          <text x="150" y="54" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">HWHash</text>
          <text x="150" y="63" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2017</text>

          <!-- Bottom text -->
          <text x="100" y="85" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6.5" font-family="var(--font-mono)">Each was right for its time.</text>
          <text x="100" y="98" text-anchor="middle" fill="#e74c3c" font-size="6.5" font-family="var(--font-mono)">Each has been overtaken.</text>

          <!-- 5-10 year lock-in -->
          <rect x="35" y="110" width="130" height="20" rx="3" fill="#e74c3c" fill-opacity="0.08" stroke="#e74c3c" stroke-width="1" />
          <text x="100" y="123" text-anchor="middle" fill="#e74c3c" font-size="6.5" font-family="var(--font-mono)">5-10 year lock-in per choice</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">Why It Matters</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Choose once, live with it forever</text>
        </g>

        <!-- Stage 2: The Field -->
        <g id="hash-stage-2" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">9 Algorithms, 3 Categories</text>

          <!-- Non-crypto -->
          <rect x="15" y="28" width="55" height="50" rx="3" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="42" y="40" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)" font-weight="bold">Speed</text>
          <text x="42" y="52" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">CRC32C</text>
          <text x="42" y="62" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">XXHash3</text>
          <text x="42" y="72" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">XXH128</text>

          <!-- Keyed PRF -->
          <rect x="75" y="28" width="50" height="50" rx="3" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="100" y="40" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)" font-weight="bold">Keyed</text>
          <text x="100" y="52" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">SipHash</text>
          <text x="100" y="62" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">HWHash</text>

          <!-- Crypto -->
          <rect x="130" y="28" width="55" height="50" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.05" />
          <text x="157" y="40" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)" font-weight="bold">Crypto</text>
          <text x="157" y="52" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">SHA-256</text>
          <text x="157" y="62" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">BLAKE2</text>
          <text x="157" y="72" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)" font-weight="bold">BLAKE3</text>

          <!-- Speed spectrum -->
          <text x="100" y="95" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Throughput range:</text>
          <text x="40" y="110" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">0.22 GB/s</text>
          <text x="100" y="110" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8">→</text>
          <text x="160" y="110" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">97 GB/s</text>
          <text x="40" y="121" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">SHA-256 sw</text>
          <text x="160" y="121" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">CRC32C hw</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">The Contenders</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">440x speed range across the field</text>
        </g>

        <!-- Stage 3: Legacy (CRC32C, MD5) -->
        <g id="hash-stage-3" class="hash-stage">
          <!-- CRC32C -->
          <rect x="15" y="15" width="80" height="65" rx="4" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="55" y="30" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)" font-weight="bold">CRC32C</text>
          <text x="55" y="43" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">97 GB/s (hw)</text>
          <text x="55" y="55" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">32-bit output</text>
          <text x="55" y="67" text-anchor="middle" fill="#e74c3c" font-size="5" font-family="var(--font-mono)">65K attempts = collision</text>
          <text x="55" y="77" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">1975</text>

          <!-- MD5 -->
          <rect x="105" y="15" width="80" height="65" rx="4" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="145" y="30" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)" font-weight="bold">MD5</text>
          <text x="145" y="43" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">0.69 GB/s</text>
          <text x="145" y="55" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">BROKEN (2004)</text>
          <text x="145" y="67" text-anchor="middle" fill="#e74c3c" font-size="5" font-family="var(--font-mono)">collision in <1s</text>
          <text x="145" y="77" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">1992</text>

          <!-- S3 ETag callout -->
          <text x="100" y="100" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">S3 still requires MD5 for ETags.</text>
          <text x="100" y="114" text-anchor="middle" fill="#e74c3c" font-size="6.5" font-family="var(--font-mono)">17 GB/s wasted on a broken algo.</text>

          <text x="100" y="135" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">CRC32C: too small at PB scale</text>
          <text x="100" y="148" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">MD5: dead since 2004</text>

          <text x="100" y="178" text-anchor="middle" fill="#e74c3c" font-size="10" font-family="var(--font-sans)">The Old Guard</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Fast or broken, pick your poison</text>
        </g>

        <!-- Stage 4: SHA-256 / SHA-3 -->
        <g id="hash-stage-4" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The Compliance Hashes</text>

          <!-- SHA-256 -->
          <rect x="20" y="28" width="75" height="62" rx="4" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="57" y="42" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">SHA-256</text>
          <text x="57" y="55" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">FIPS ✓</text>
          <text x="57" y="67" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">1.5 GB/s (hw)</text>
          <text x="57" y="79" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">128-bit security</text>
          <text x="57" y="88" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2001</text>

          <!-- SHA-3 -->
          <rect x="105" y="28" width="75" height="62" rx="4" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="142" y="42" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)" font-weight="bold">SHA-3</text>
          <text x="142" y="55" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">FIPS ✓</text>
          <text x="142" y="67" text-anchor="middle" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">0.55 GB/s</text>
          <text x="142" y="79" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">No x86 hw accel</text>
          <text x="142" y="88" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2015</text>

          <!-- Performance penalty -->
          <text x="100" y="110" text-anchor="middle" fill="#e74c3c" font-size="6.5" font-family="var(--font-mono)">4-7x slower than BLAKE3</text>
          <text x="100" y="125" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">The price of a NIST stamp.</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="10" font-family="var(--font-sans)">The FIPS Tax</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Mandated, not optimal</text>
        </g>

        <!-- Stage 5: XXHash3, SipHash -->
        <g id="hash-stage-5" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The Speed Demons</text>

          <!-- XXHash3 bar -->
          <rect x="20" y="30" width="160" height="22" rx="3" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="1" />
          <text x="30" y="44" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">XXHash3</text>
          <text x="170" y="44" text-anchor="end" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">31.5 GB/s</text>

          <!-- SipHash bar (shorter) -->
          <rect x="20" y="58" width="40" height="22" rx="3" fill="var(--color-text-tertiary)" fill-opacity="0.1" stroke="var(--color-text-tertiary)" stroke-width="1" />
          <text x="30" y="72" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">SipHash</text>
          <text x="75" y="72" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">2 GB/s</text>

          <!-- Characteristics -->
          <text x="30" y="98" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">XXHash3:</text>
          <text x="30" y="110" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">✓ Fastest non-crypto hash</text>
          <text x="30" y="121" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">✗ Zero adversarial resistance</text>

          <text x="30" y="138" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">SipHash:</text>
          <text x="30" y="149" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">✓ Rust HashMap default</text>
          <text x="30" y="160" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">✗ Too slow for bulk data</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">Speed Demons</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Fast but not secure</text>
        </g>

        <!-- Stage 6: HighwayHash -->
        <g id="hash-stage-6" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The Keyed Speedster</text>

          <!-- HighwayHash card -->
          <rect x="25" y="28" width="150" height="55" rx="4" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-surface-alt)" />
          <text x="100" y="42" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-mono)" font-weight="bold">HighwayHash-256</text>
          <text x="100" y="55" text-anchor="middle" fill="var(--color-accent)" font-size="6.5" font-family="var(--font-mono)">10-12 GB/s (AVX2)</text>
          <text x="100" y="67" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Keyed PRF + SIMD native</text>
          <text x="100" y="78" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Right call in 2017</text>

          <!-- Pros -->
          <text x="30" y="98" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">✓ Bitrot on every read</text>
          <text x="30" y="110" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">✓ Auto-heal from parity</text>

          <!-- Cons -->
          <text x="30" y="126" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">✗ Requires secret key</text>
          <text x="30" y="138" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">✗ No content addressing</text>
          <text x="30" y="150" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">✗ Limited cryptanalysis</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">HighwayHash</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Great for closed systems</text>
        </g>

        <!-- Stage 7: BLAKE3 -->
        <g id="hash-stage-7" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-mono)" font-weight="bold">BLAKE3</text>

          <!-- Merkle tree diagram -->
          <rect x="30" y="28" width="25" height="12" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.8" />
          <rect x="60" y="28" width="25" height="12" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.8" />
          <rect x="90" y="28" width="25" height="12" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.8" />
          <rect x="120" y="28" width="25" height="12" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.8" />
          <rect x="150" y="28" width="25" height="12" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.8" />
          <text x="42" y="37" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">h₀</text>
          <text x="72" y="37" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">h₁</text>
          <text x="102" y="37" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">h₂</text>
          <text x="132" y="37" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">h₃</text>
          <text x="162" y="37" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">...</text>

          <!-- Merge lines -->
          <line x1="42" y1="40" x2="57" y2="52" stroke="var(--color-accent)" stroke-width="0.8" />
          <line x1="72" y1="40" x2="57" y2="52" stroke="var(--color-accent)" stroke-width="0.8" />
          <line x1="102" y1="40" x2="140" y2="52" stroke="var(--color-accent)" stroke-width="0.8" />
          <line x1="132" y1="40" x2="140" y2="52" stroke="var(--color-accent)" stroke-width="0.8" />

          <circle cx="57" cy="55" r="4" fill="var(--color-accent)" fill-opacity="0.2" stroke="var(--color-accent)" stroke-width="0.8" />
          <circle cx="140" cy="55" r="4" fill="var(--color-accent)" fill-opacity="0.2" stroke="var(--color-accent)" stroke-width="0.8" />

          <line x1="57" y1="59" x2="100" y2="68" stroke="var(--color-accent)" stroke-width="0.8" />
          <line x1="140" y1="59" x2="100" y2="68" stroke="var(--color-accent)" stroke-width="0.8" />

          <circle cx="100" cy="71" r="5" fill="var(--color-accent)" fill-opacity="0.3" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="74" text-anchor="middle" fill="var(--color-accent)" font-size="4" font-family="var(--font-mono)">root</text>
          <text x="100" y="85" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">Merkle tree = parallel by design</text>

          <!-- Stats -->
          <text x="30" y="100" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">6.4 GB/s single-threaded</text>
          <text x="30" y="112" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">15.8 GB/s multi-threaded</text>
          <text x="30" y="124" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">128-bit crypto security</text>
          <text x="30" y="136" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Streaming verification</text>
          <text x="30" y="148" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Post-quantum via XOF</text>
          <text x="30" y="160" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">No FIPS (yet)</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)" font-weight="600">The Future</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Fast AND secure. Finally.</text>
        </g>

        <!-- Stage 8: The Verdict -->
        <g id="hash-stage-8" class="hash-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">2026-2031 Outlook</text>

          <!-- Rising -->
          <text x="30" y="35" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">Rising:</text>
          <text x="30" y="47" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">BLAKE3 → new default</text>

          <!-- Stable -->
          <text x="30" y="64" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)" font-weight="bold">Stable:</text>
          <text x="30" y="76" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">SHA-256 (compliance only)</text>
          <text x="30" y="88" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">XXHash3 (non-crypto speed)</text>

          <!-- Declining -->
          <text x="30" y="105" fill="#e74c3c" font-size="6" font-family="var(--font-mono)" font-weight="bold">Declining:</text>
          <text x="30" y="117" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">HighwayHash (gap < 2x now)</text>
          <text x="30" y="129" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">BLAKE2 (superseded)</text>
          <text x="30" y="141" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">MD5 (dead but undead)</text>

          <!-- Bottom line -->
          <rect x="25" y="150" width="150" height="18" rx="3" fill="var(--color-accent)" fill-opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="162" text-anchor="middle" fill="var(--color-accent)" font-size="6.5" font-family="var(--font-mono)">Fast vs secure is a false choice.</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)" font-weight="600">The Verdict</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">BLAKE3 is both</text>
        </g>
      </svg>
    </div>

    <!-- Metric panel -->
    <div class="mt-4 rounded-lg bg-[var(--color-surface-alt)] px-3 py-2.5 text-center">
      <p class="text-[9px] uppercase tracking-widest text-[var(--color-text-tertiary)]" id="hash-metric-label">Lock-in Period</p>
      <p class="mt-1 font-mono text-lg font-bold text-[var(--color-accent)]">
        <span id="hash-metric-value">5-10</span>
        <span id="hash-metric-unit" class="text-sm font-normal"> years</span>
      </p>
      <p id="hash-metric-sub" class="text-[9px] text-[var(--color-text-tertiary)]">per hash algorithm choice</p>
    </div>

    <!-- Stage dots -->
    <div class="mt-3 flex justify-center gap-1.5">
      <div class="hash-dot active" data-stage="1"></div>
      <div class="hash-dot" data-stage="2"></div>
      <div class="hash-dot" data-stage="3"></div>
      <div class="hash-dot" data-stage="4"></div>
      <div class="hash-dot" data-stage="5"></div>
      <div class="hash-dot" data-stage="6"></div>
      <div class="hash-dot" data-stage="7"></div>
      <div class="hash-dot" data-stage="8"></div>
    </div>

    <!-- ELI10 -->
    <div class="mt-5 rounded-lg border border-[var(--color-border)]/30 bg-[var(--color-surface-alt)]/50 px-3.5 py-3">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
        Explain Like I'm 10
      </p>
      <p id="hash-eli10-text" class="hash-eli10-fade mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)]">
        When you save a file, the computer writes down a secret code that describes it. Later, when you open the file, it checks the code. If the code doesn't match, something went wrong. The problem? Some of these codes are way too short, like using a 2-digit password for your diary.
      </p>
    </div>
  </div>
</aside>

<style>
  .hash-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .hash-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .hash-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .hash-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .hash-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .hash-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .hash-eli10-fade {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .hash-eli10-fade.changing {
    opacity: 0;
    transform: translateY(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .hash-stage { transition: none; }
    .hash-dot { transition: none; }
    .hash-eli10-fade { transition: none; }
  }
</style>

<script>
  function initHashEvolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("why this matters")) stage = 1;
      else if (text.includes("contenders")) stage = 2;
      else if (text.includes("non-cryptographic")) stage = 2;
      else if (text.includes("keyed prf")) stage = 2;
      else if (text.includes("cryptographic hash")) stage = 2;
      else if (text.includes("algorithm by algorithm")) stage = 3;
      else if (text.includes("crc32c")) stage = 3;
      else if (text.includes("md5")) stage = 3;
      else if (text.includes("sha-256")) stage = 4;
      else if (text.includes("sha-3")) stage = 4;
      else if (text.includes("xxhash")) stage = 5;
      else if (text.includes("siphash")) stage = 5;
      else if (text.includes("highwayhash")) stage = 6;
      else if (text.includes("blake2")) stage = 7;
      else if (text.includes("blake3")) stage = 7;
      else if (text.includes("decision matrix")) stage = 8;
      else if (text.includes("fips compliance")) stage = 8;
      else if (text.includes("non-cryptographic speed")) stage = 8;
      else if (text.includes("keyed integrity")) stage = 8;
      else if (text.includes("building new")) stage = 8;
      else if (text.includes("next five years")) stage = 8;
      else if (text.includes("uncomfortable truth")) stage = 8;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".hash-stage");
    const dots = document.querySelectorAll(".hash-dot");
    const metricLabel = document.getElementById("hash-metric-label");
    const metricValue = document.getElementById("hash-metric-value");
    const metricUnit = document.getElementById("hash-metric-unit");
    const metricSub = document.getElementById("hash-metric-sub");

    const metricData = [
      { label: "Lock-in Period", value: "5-10", unit: " years", sub: "per hash algorithm choice" },
      { label: "Speed Range", value: "440x", unit: "", sub: "0.22 to 97 GB/s" },
      { label: "CRC32C Collisions", value: "65K", unit: " tries", sub: "brute-force on a laptop" },
      { label: "SHA-256 vs BLAKE3", value: "4-7x", unit: " slower", sub: "the FIPS performance tax" },
      { label: "XXHash3 Speed", value: "31.5", unit: " GB/s", sub: "faster than DRAM bandwidth" },
      { label: "HighwayHash", value: "10-12", unit: " GB/s", sub: "keyed, not cryptographic" },
      { label: "BLAKE3 (AVX2)", value: "6.4", unit: " GB/s", sub: "cryptographic + parallel" },
      { label: "BLAKE3 Gap", value: "<2x", unit: "", sub: "vs HighwayHash, with crypto strength" },
    ];

    const eli10El = document.getElementById("hash-eli10-text");
    const eli10Data = [
      "When you save a file, the computer writes down a secret code that describes it. Later, when you open the file, it checks the code. If the code doesn't match, something went wrong. The problem? Some of these codes are way too short, like using a 2-digit password for your diary.",
      "There are nine different ways to make these codes. Some are super fast but easy to fool. Some are super secure but really slow. And one of them (BLAKE3) figured out how to be both fast AND secure, which everyone thought was impossible.",
      "CRC32C is like checking if a book still has the right number of pages. Quick, but someone could swap pages and you'd never know. MD5 is like a lock that everyone figured out how to pick 20 years ago, but Amazon still uses it because they can't change the locks on a billion doors.",
      "SHA-256 is the padlock the government says you must use. It's strong, but it takes forever to lock and unlock. SHA-3 is an even slower backup padlock, just in case someone breaks SHA-256. Nobody wants to use it, but NIST says keep one in the drawer.",
      "XXHash3 is like counting by calculator instead of by hand. Incredibly fast, but it's only checking if things add up, not if someone's cheating. SipHash is the tiny padlock on your Rust HashMap. Perfect for little things, too small for guarding a warehouse.",
      "HighwayHash is the lock MinIO chose. Really fast, really good at catching bit rot. But you need the secret key to check anything, and you can't compare notes with anyone outside your system. Like a secret handshake that only works at one school.",
      "BLAKE3 is like a team of kids splitting up a puzzle, each solving their section at the same time, then clicking all sections together. Every other hash makes one kid do the whole puzzle alone. That's why BLAKE3 is so much faster. And it's just as secure as the slower ones.",
      "The world used to think you could have fast hashing or secure hashing, but not both. That's over. BLAKE3 is the answer for anything built from now on. SHA-256 stays for paperwork, MD5 stays because Amazon, and everything else is fading out.",
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }

      if (eli10El && eli10Data[stage - 1]) {
        eli10El.classList.add("changing");
        setTimeout(() => {
          eli10El.textContent = eli10Data[stage - 1];
          eli10El.classList.remove("changing");
        }, 200);
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initHashEvolution();
</script>
