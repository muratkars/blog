---
---

<aside class="edsff-evolution hidden lg:block">
  <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
      EDSFF Form Factor Guide
    </p>

    <div class="svg-container">
      <svg viewBox="0 0 200 230" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">

        <!-- Stage 1: Form Factor History -->
        <g id="edsff-stage-1" class="edsff-stage active">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">Form Factor Timeline</text>

          <line x1="30" y1="35" x2="170" y2="35" stroke="var(--color-border)" stroke-width="1" />

          <!-- 3.5" HDD -->
          <circle cx="45" cy="35" r="3" fill="var(--color-text-tertiary)" />
          <rect x="25" y="45" width="40" height="30" rx="3" stroke="var(--color-text-tertiary)" stroke-width="0.8" fill="var(--color-surface-alt)" />
          <text x="45" y="58" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">3.5"</text>
          <text x="45" y="68" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">HDD</text>
          <text x="45" y="84" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">1998</text>

          <!-- 2.5" SSD -->
          <circle cx="100" cy="35" r="3" fill="var(--color-text-tertiary)" />
          <rect x="83" y="48" width="34" height="24" rx="3" stroke="var(--color-text-tertiary)" stroke-width="0.8" fill="var(--color-surface-alt)" />
          <text x="100" y="59" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">2.5"</text>
          <text x="100" y="68" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">SSD</text>
          <text x="100" y="84" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2008</text>

          <!-- M.2 -->
          <circle cx="140" cy="35" r="3" fill="var(--color-text-tertiary)" />
          <rect x="125" y="53" width="30" height="8" rx="2" stroke="var(--color-text-tertiary)" stroke-width="0.8" fill="var(--color-surface-alt)" />
          <text x="140" y="60" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">M.2</text>
          <text x="140" y="73" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2013</text>

          <!-- EDSFF arrow -->
          <line x1="100" y1="92" x2="100" y2="108" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#edsff-arrow)" />
          <rect x="55" y="110" width="90" height="20" rx="3" fill="var(--color-accent)" fill-opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="123" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">EDSFF (2018)</text>

          <text x="100" y="148" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Flat rectangles pack better</text>
          <text x="100" y="160" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">than square boxes. Always did.</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">Form Factor History</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">26 years of the 2.5-inch bay</text>

          <defs>
            <marker id="edsff-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
              <path d="M0,0 L6,3 L0,6" fill="var(--color-accent)" />
            </marker>
          </defs>
        </g>

        <!-- Stage 2: The EDSFF Family -->
        <g id="edsff-stage-2" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The EDSFF Family</text>

          <!-- E1.S -->
          <rect x="15" y="30" width="80" height="18" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.05" />
          <text x="55" y="42" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">E1.S</text>

          <!-- E1.L -->
          <rect x="15" y="54" width="170" height="18" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.05" />
          <text x="100" y="66" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">E1.L</text>

          <!-- E3.S -->
          <rect x="15" y="78" width="80" height="30" rx="3" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="55" y="96" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)" font-weight="bold">E3.S</text>

          <!-- E3.L -->
          <rect x="105" y="78" width="80" height="30" rx="3" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="145" y="96" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)" font-weight="bold">E3.L</text>

          <!-- Specs -->
          <text x="30" y="125" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">E1.S: short, slim, hot-swap</text>
          <text x="30" y="137" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">E1.L: ruler, max density</text>
          <text x="30" y="149" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">E3.S: wide, high perf</text>
          <text x="30" y="161" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">E3.L: full-length, GPU-tier</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">The EDSFF Family</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">4 variants for every workload</text>
        </g>

        <!-- Stage 3: E1.S Revolution -->
        <g id="edsff-stage-3" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">E1.S Revolution</text>

          <!-- Drive outline -->
          <rect x="35" y="28" width="130" height="28" rx="4" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-accent)" fill-opacity="0.05" />
          <text x="100" y="46" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-mono)" font-weight="bold">E1.S</text>

          <!-- Stats -->
          <text x="30" y="72" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">32 drives in 1U</text>
          <text x="30" y="84" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Hot-swappable</text>
          <text x="30" y="96" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Front-load, front-cool</text>

          <!-- Adoption bar -->
          <text x="30" y="115" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">PCIe SSD market share by 2027:</text>
          <rect x="30" y="120" width="140" height="14" rx="2" fill="var(--color-border)" fill-opacity="0.3" />
          <rect x="30" y="120" width="56" height="14" rx="2" fill="var(--color-accent)" fill-opacity="0.3" />
          <text x="63" y="130" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)" font-weight="bold">40%</text>

          <!-- Adopters -->
          <text x="30" y="150" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Meta, Microsoft, Google</text>
          <text x="30" y="162" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">already shipping E1.S at scale</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">E1.S Revolution</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">40% of PCIe SSDs by 2027</text>
        </g>

        <!-- Stage 4: E1.L Density -->
        <g id="edsff-stage-4" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">E1.L Density Math</text>

          <!-- Ruler drive -->
          <rect x="10" y="30" width="180" height="14" rx="3" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="100" y="40" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">E1.L ruler (318mm)</text>

          <!-- Density progression -->
          <text x="30" y="62" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Today: 61.6 TB per drive</text>
          <text x="30" y="74" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">32 drives per 1U = 1.97 PB</text>

          <line x1="100" y1="80" x2="100" y2="92" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="88" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-sans)">&#8595;</text>

          <text x="30" y="105" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">2027: 245 TB per drive</text>
          <text x="30" y="117" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">32 drives per 1U = 7.86 PB</text>

          <!-- Visual: stacked rulers -->
          <rect x="25" y="128" width="150" height="4" rx="1" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.5" />
          <rect x="25" y="134" width="150" height="4" rx="1" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.5" />
          <rect x="25" y="140" width="150" height="4" rx="1" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.5" />
          <rect x="25" y="146" width="150" height="4" rx="1" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.5" />
          <text x="100" y="163" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">32 rulers stacked in 1U</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">E1.L Density</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">7.86 PB in a pizza box</text>
        </g>

        <!-- Stage 5: E2 Petabyte Drive -->
        <g id="edsff-stage-5" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">E2: The Petabyte Drive</text>

          <!-- Single E2 drive -->
          <rect x="30" y="30" width="140" height="35" rx="4" stroke="var(--color-accent)" stroke-width="2" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="100" y="44" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-mono)" font-weight="bold">1 PB</text>
          <text x="100" y="58" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">per E2 drive</text>

          <!-- 2U chassis -->
          <rect x="20" y="75" width="160" height="30" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="100" y="88" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">||||||||||||||||||||||||||||||||||||||||</text>
          <text x="100" y="100" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">40 drives in 2U chassis</text>

          <!-- Math -->
          <rect x="30" y="115" width="140" height="30" rx="4" fill="var(--color-accent)" fill-opacity="0.1" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="128" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">40 PB per chassis</text>
          <text x="100" y="140" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">SFF-TA-1042 connector</text>

          <text x="100" y="162" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Used to require a room of HDDs.</text>
          <text x="100" y="174" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Now it's 2 inches of rack space.</text>

          <text x="100" y="195" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">E2 Petabyte Drive</text>
          <text x="100" y="210" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">40 PB in 2U</text>
        </g>

        <!-- Stage 6: Software Problems -->
        <g id="edsff-stage-6" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)" font-weight="bold">Software Must Catch Up</text>

          <!-- Problem list -->
          <rect x="15" y="28" width="170" height="22" rx="3" fill="#e74c3c" fill-opacity="0.06" stroke="#e74c3c" stroke-width="0.8" />
          <text x="25" y="42" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">1. Rebuild: 23 days for 1 PB @ 500 MB/s</text>

          <rect x="15" y="54" width="170" height="22" rx="3" fill="#e74c3c" fill-opacity="0.06" stroke="#e74c3c" stroke-width="0.8" />
          <text x="25" y="68" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">2. Failure domain: 1 PB per drive</text>

          <rect x="15" y="80" width="170" height="22" rx="3" fill="#e74c3c" fill-opacity="0.06" stroke="#e74c3c" stroke-width="0.8" />
          <text x="25" y="94" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">3. PCIe lanes: 128 per CPU max</text>

          <rect x="15" y="106" width="170" height="22" rx="3" fill="#e74c3c" fill-opacity="0.06" stroke="#e74c3c" stroke-width="0.8" />
          <text x="25" y="120" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">4. Power: 25W per E2 drive</text>

          <rect x="15" y="132" width="170" height="22" rx="3" fill="#e74c3c" fill-opacity="0.06" stroke="#e74c3c" stroke-width="0.8" />
          <text x="25" y="146" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">5. QLC write amplification</text>

          <text x="100" y="172" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">Hardware got there first.</text>
          <text x="100" y="184" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">Software is the bottleneck.</text>

          <text x="100" y="205" text-anchor="middle" fill="#e74c3c" font-size="10" font-family="var(--font-sans)">Software Problems</text>
          <text x="100" y="220" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">5 problems, no easy answers</text>
        </g>

        <!-- Stage 7: The 1 PB Node -->
        <g id="edsff-stage-7" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The 1 PB Node</text>

          <!-- Server box -->
          <rect x="20" y="28" width="160" height="75" rx="4" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-surface-alt)" />

          <!-- Dual socket -->
          <rect x="30" y="35" width="30" height="16" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.6" />
          <text x="45" y="46" text-anchor="middle" fill="var(--color-accent)" font-size="4.5" font-family="var(--font-mono)">CPU 0</text>
          <rect x="65" y="35" width="30" height="16" rx="2" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="0.6" />
          <text x="80" y="46" text-anchor="middle" fill="var(--color-accent)" font-size="4.5" font-family="var(--font-mono)">CPU 1</text>

          <!-- RAM -->
          <rect x="105" y="35" width="65" height="16" rx="2" fill="var(--color-text-tertiary)" fill-opacity="0.1" stroke="var(--color-text-tertiary)" stroke-width="0.6" />
          <text x="137" y="46" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">512 GB RAM</text>

          <!-- Drive slots -->
          <rect x="30" y="58" width="140" height="14" rx="2" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="100" y="68" text-anchor="middle" fill="var(--color-accent)" font-size="4.5" font-family="var(--font-mono)">32x E1.L drives (30.7 TB each)</text>

          <!-- NIC -->
          <rect x="30" y="78" width="65" height="14" rx="2" fill="var(--color-text-tertiary)" fill-opacity="0.1" stroke="var(--color-text-tertiary)" stroke-width="0.6" />
          <text x="62" y="88" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">2x 100GbE</text>

          <rect x="105" y="78" width="65" height="14" rx="2" fill="var(--color-text-tertiary)" fill-opacity="0.1" stroke="var(--color-text-tertiary)" stroke-width="0.6" />
          <text x="137" y="88" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="4.5" font-family="var(--font-mono)">PCIe Gen5</text>

          <!-- Total -->
          <rect x="30" y="112" width="140" height="22" rx="3" fill="var(--color-accent)" fill-opacity="0.1" stroke="var(--color-accent)" stroke-width="1" />
          <text x="100" y="126" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">983 TB raw per 1U</text>

          <!-- Rack math -->
          <text x="30" y="150" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">42 nodes per rack</text>
          <text x="30" y="162" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">= 40 PB raw per rack</text>

          <text x="100" y="185" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">The 1 PB Node</text>
          <text x="100" y="200" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">983 TB in 1U, dual-socket</text>
        </g>

        <!-- Stage 8: The Verdict -->
        <g id="edsff-stage-8" class="edsff-stage">
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">The Verdict</text>

          <!-- Rack visualization -->
          <rect x="70" y="28" width="60" height="90" rx="3" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-surface-alt)" />
          <rect x="75" y="32" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="37" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="42" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="47" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="52" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="57" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="62" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="67" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="72" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="77" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="82" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="87" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="92" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="97" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="102" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="107" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />
          <rect x="75" y="112" width="50" height="3" rx="1" fill="var(--color-accent)" fill-opacity="0.3" />

          <text x="100" y="128" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">1 rack (E2)</text>

          <!-- Big number -->
          <rect x="25" y="135" width="150" height="28" rx="4" fill="var(--color-accent)" fill-opacity="0.1" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="100" y="154" text-anchor="middle" fill="var(--color-accent)" font-size="11" font-family="var(--font-mono)" font-weight="bold">~0.5 Exabyte</text>

          <text x="100" y="176" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Form factor: ready</text>
          <text x="100" y="188" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Hardware: shipping</text>
          <text x="100" y="200" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">Software: must follow</text>

          <text x="100" y="218" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)" font-weight="600">The Verdict</text>
        </g>
      </svg>
    </div>

    <!-- Metric panel -->
    <div class="mt-4 rounded-lg bg-[var(--color-surface-alt)] px-3 py-2.5 text-center">
      <p class="text-[9px] uppercase tracking-widest text-[var(--color-text-tertiary)]" id="edsff-metric-label">Form Factor Age</p>
      <p class="mt-1 font-mono text-lg font-bold text-[var(--color-accent)]">
        <span id="edsff-metric-value">26</span>
        <span id="edsff-metric-unit" class="text-sm font-normal"> years</span>
      </p>
      <p id="edsff-metric-sub" class="text-[9px] text-[var(--color-text-tertiary)]">2.5-inch SSD bay still standard</p>
    </div>

    <!-- Stage dots -->
    <div class="mt-3 flex justify-center gap-1.5">
      <div class="edsff-dot active" data-stage="1"></div>
      <div class="edsff-dot" data-stage="2"></div>
      <div class="edsff-dot" data-stage="3"></div>
      <div class="edsff-dot" data-stage="4"></div>
      <div class="edsff-dot" data-stage="5"></div>
      <div class="edsff-dot" data-stage="6"></div>
      <div class="edsff-dot" data-stage="7"></div>
      <div class="edsff-dot" data-stage="8"></div>
    </div>

    <!-- ELI10 -->
    <div class="mt-5 rounded-lg border border-[var(--color-border)]/30 bg-[var(--color-surface-alt)]/50 px-3.5 py-3">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
        Explain Like I'm 10
      </p>
      <p id="edsff-eli10-text" class="edsff-eli10-fade mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)]">
        Hard drives used to be the size of a lunch box. Then they shrunk to a deck of cards. Now we're making them the shape of rulers because it turns out flat rectangles pack way better than boxes. Who knew?
      </p>
    </div>
  </div>
</aside>

<style>
  .edsff-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .edsff-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .edsff-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .edsff-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .edsff-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .edsff-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .edsff-eli10-fade {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .edsff-eli10-fade.changing {
    opacity: 0;
    transform: translateY(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .edsff-stage { transition: none; }
    .edsff-dot { transition: none; }
    .edsff-eli10-fade { transition: none; }
  }
</style>

<script>
  function initEDSFFEvolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("brief history") || text.includes("putting storage")) stage = 1;
      else if (text.includes("3.5-inch") || text.includes("2.5-inch") || text.includes("m.2")) stage = 1;
      else if (text.includes("enter edsff") || text.includes("edsff family")) stage = 2;
      else if (text.includes("e1.s")) stage = 3;
      else if (text.includes("e1.l")) stage = 4;
      else if (text.includes("e3.s") || text.includes("e3.l")) stage = 4;
      else if (text.includes("e2") || text.includes("petabyte drive")) stage = 5;
      else if (text.includes("sff-ta-1042") || text.includes("who's building") || text.includes("warm data") || text.includes("40 pb")) stage = 5;
      else if (text.includes("software implications") || text.includes("problem 1") || text.includes("problem 2") || text.includes("problem 3") || text.includes("problem 4") || text.includes("problem 5")) stage = 6;
      else if (text.includes("rebuild times") || text.includes("failure domain") || text.includes("pcie lane") || text.includes("power and thermal") || text.includes("qlc write")) stage = 6;
      else if (text.includes("what's actually shipping")) stage = 7;
      else if (text.includes("1 pb node") || text.includes("architecture sketch") || text.includes("software stack")) stage = 7;
      else if (text.includes("data center impact") || text.includes("network") || text.includes("power") || text.includes("operational")) stage = 8;
      else if (text.includes("conclusion")) stage = 8;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".edsff-stage");
    const dots = document.querySelectorAll(".edsff-dot");
    const metricLabel = document.getElementById("edsff-metric-label");
    const metricValue = document.getElementById("edsff-metric-value");
    const metricUnit = document.getElementById("edsff-metric-unit");
    const metricSub = document.getElementById("edsff-metric-sub");

    const metricData = [
      { label: "Form Factor Age", value: "26", unit: " years", sub: "2.5-inch SSD bay still standard" },
      { label: "EDSFF Variants", value: "4", unit: " types", sub: "E1.S, E1.L, E3.S, E3.L + E2" },
      { label: "E1.S Market Share", value: "40%", unit: " by 2027", sub: "of PCIe SSD units shipped" },
      { label: "E1.L Density", value: "7.86", unit: " PB/1U", sub: "32x E1.L at 245 TB each" },
      { label: "E2 Per Chassis", value: "40", unit: " PB", sub: "40x E2 at 1 PB in 2U" },
      { label: "1 PB Rebuild", value: "23", unit: " days", sub: "at 500 MB/s sustained" },
      { label: "Per Rack", value: "40", unit: " PB raw", sub: "42x 1U EDSFF nodes" },
      { label: "Per Rack (E2)", value: "840", unit: " PB", sub: "half an exabyte, one rack" },
    ];

    const eli10El = document.getElementById("edsff-eli10-text");
    const eli10Data = [
      "Hard drives used to be the size of a lunch box. Then they shrunk to a deck of cards. Now we're making them the shape of rulers because it turns out flat rectangles pack way better than boxes. Who knew?",
      "EDSFF is like having different LEGO brick sizes for different jobs. Short ones for quick storage, long rulers for maximum space, wide ones for speed. They all click into the same backplane, no cables.",
      "E1.S is the new standard that nobody's talking about but everybody's buying. It's slim enough that you can line up 32 of them in a pizza box-sized server. Meta and Microsoft already switched.",
      "Imagine filling your bookshelf with rulers instead of books. Each ruler holds 245 terabytes. One shelf holds almost 8 petabytes. That's enough to store every movie ever made, twice, in a space the size of a pizza box.",
      "E2 is the one that changes everything. One drive, one petabyte. Forty drives in a server. Forty petabytes. That used to require an entire room of hard drives. Now it's two inches of rack space.",
      "When a petabyte drive breaks, fixing it takes 23 days. That's like being told your backup plan needs three weeks to kick in. The software has to get way smarter about how it protects your data.",
      "A single server rack with these new drives holds 40 petabytes. That's roughly all the text ever written by humans, stored in something the size of a fridge. The software running on it needs to be just as impressive.",
      "Half an exabyte in one rack. The drives are ready. The servers are designed. The question is whether storage software can keep up. Most can't. That's why this matters.",
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }

      if (eli10El && eli10Data[stage - 1]) {
        eli10El.classList.add("changing");
        setTimeout(() => {
          eli10El.textContent = eli10Data[stage - 1];
          eli10El.classList.remove("changing");
        }, 200);
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initEDSFFEvolution();
</script>
