</aside>

<style>
  .sdc-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .sdc-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .sdc-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .sdc-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .sdc-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .sdc-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .sdc-eli10-fade {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .sdc-eli10-fade.changing {
    opacity: 0;
    transform: translateY(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .sdc-stage { transition: none; }
    .sdc-dot { transition: none; }
    .sdc-eli10-fade { transition: none; }
  }
</style>

<script>
  function initSDCEvolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("confession")) stage = 1;
      else if (text.includes("cores that don")) stage = 2;
      else if (text.includes("research") && text.includes("cpu")) stage = 2;
      else if (text.includes("silent data corruptions at scale")) stage = 2;
      else if (text.includes("industry response")) stage = 2;
      else if (text.includes("math of scale")) stage = 3;
      else if (text.includes("uniquely vulnerable")) stage = 3;
      else if (text.includes("sdc during llm")) stage = 3;
      else if (text.includes("the cost")) stage = 3;
      else if (text.includes("storage systems don")) stage = 4;
      else if (text.includes("checksum gap")) stage = 4;
      else if (text.includes("zfs got right")) stage = 4;
      else if (text.includes("minio got right")) stage = 4;
      else if (text.includes("next generation must")) stage = 5;
      else if (text.includes("what this means")) stage = 6;
      else if (text.includes("training pipeline")) stage = 6;
      else if (text.includes("inference pipeline")) stage = 6;
      else if (text.includes("storage system")) stage = 6;
      else if (text.includes("hard truth")) stage = 7;
      else if (text.includes("what i do now")) stage = 7;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".sdc-stage");
    const dots = document.querySelectorAll(".sdc-dot");
    const metricLabel = document.getElementById("sdc-metric-label");
    const metricValue = document.getElementById("sdc-metric-value");
    const metricUnit = document.getElementById("sdc-metric-unit");
    const metricSub = document.getElementById("sdc-metric-sub");

    const metricData = [
      { label: "Years in Storage", value: "7+", unit: " years", sub: "Nexenta (ZFS) + MinIO" },
      { label: "Affected Servers", value: "1:1,000", unit: "", sub: "Google + Meta confirmed" },
      { label: "SDC in Llama 3", value: "6", unit: " events", sub: "in a single 54-day run" },
      { label: "Detection Gap", value: "30%", unit: "", sub: "evade Meta's best tools" },
      { label: "BLAKE3 Speed", value: "10+", unit: " GB/s", sub: "per core, no excuses" },
      { label: "Cost per SDC Event", value: "$100K+", unit: "", sub: "wasted GPU compute" },
      { label: "Checksum Layers", value: "4", unit: " deep", sub: "ingest → compress → encrypt → shard" },
    ];

    const eli10El = document.getElementById("sdc-eli10-text");
    const eli10Data = [
      "Imagine spending years as a lifeguard, then going home and forgetting to lock your own pool gate. That's basically what happened. I worked at two companies that protect data, then lost my own family photos because I got lazy with my home setup.",
      "Your computer has a little calculator inside called a CPU. Usually it gets the right answer. But Google found that about 1 in every 1,000 computers has a calculator that sometimes gets math wrong, and it doesn't even know it's wrong. It just confidently says 2+2=5.",
      "When you teach a robot to recognize cats by showing it millions of pictures, and some of those pictures are secretly scrambled, the robot learns weird things. It won't crash or complain. It'll just be a little bit wrong about cats forever, and nobody will know why.",
      "Your hard drive has a spell-checker for data. But the problem happens before the data gets to the hard drive. It's like spell-checking a paper after someone already changed the words. The spell-checker says \"looks good!\" because the wrong words are spelled correctly.",
      "The fix is to check your homework at every step. Write an essay, check it. Translate it to French, check it. Print it, check it. If anything changed between steps, you know exactly where it went wrong and can redo just that part.",
      "Training a big AI is like a thousand kids working on one giant jigsaw puzzle together. If even one kid is putting pieces in the wrong spots, the final picture looks off. You need each kid to double-check their pieces before passing them along.",
      "ZFS checks every drawer in the filing cabinet. MinIO checks every copy in every office. The next system needs to check every hand the paper passes through, because it turns out some of the people carrying the paper are accidentally smudging it.",
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }

      if (eli10El && eli10Data[stage - 1]) {
        eli10El.classList.add("changing");
        setTimeout(() => {
          eli10El.textContent = eli10Data[stage - 1];
          eli10El.classList.remove("changing");
        }, 200);
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initSDCEvolution();
</script>
