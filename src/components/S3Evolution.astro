---
---

<aside class="s3-evolution hidden lg:block">
  <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
      S3 API Evolution
    </p>

    <div class="svg-container">
      <svg viewBox="0 0 200 230" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">

        <!-- Stage 1: The Accidental Standard -->
        <g id="s3-stage-1" class="s3-stage active">
          <!-- S3 bucket icon -->
          <ellipse cx="100" cy="35" rx="55" ry="15" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-accent)" fill-opacity="0.05" />
          <line x1="45" y1="35" x2="45" y2="80" stroke="var(--color-accent)" stroke-width="1.5" />
          <line x1="155" y1="35" x2="155" y2="80" stroke="var(--color-accent)" stroke-width="1.5" />
          <ellipse cx="100" cy="80" rx="55" ry="15" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-accent)" fill-opacity="0.05" />
          <!-- 5 operations -->
          <text x="100" y="55" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">5 operations</text>
          <text x="100" y="67" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">PUT GET DELETE HEAD LIST</text>
          <!-- Year -->
          <text x="100" y="110" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-mono)">March 2006</text>
          <!-- Everything connects to it -->
          <text x="30" y="135" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">Spark</text>
          <text x="60" y="130" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">Iceberg</text>
          <text x="93" y="128" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">PyTorch</text>
          <text x="130" y="132" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">MinIO</text>
          <text x="155" y="138" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">R2</text>
          <text x="40" y="148" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">Trino</text>
          <text x="75" y="145" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">DuckDB</text>
          <text x="115" y="146" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">Ceph</text>
          <text x="145" y="150" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">HF</text>

          <text x="100" y="180" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">The Accidental Standard</text>
          <text x="100" y="195" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Won by being first, not best</text>
        </g>

        <!-- Stage 2: Seven Limitations -->
        <g id="s3-stage-2" class="s3-stage">
          <!-- Seven broken blocks -->
          <rect x="15" y="18" width="78" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="54" y="30" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">1. No Append</text>

          <rect x="105" y="18" width="80" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="145" y="30" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">2. No Partial PUT</text>

          <rect x="15" y="42" width="78" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="54" y="54" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">3. LIST is O(n)</text>

          <rect x="105" y="42" width="80" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="145" y="54" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">4. No Compute</text>

          <rect x="15" y="66" width="78" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="54" y="78" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">5. XML in 2026</text>

          <rect x="105" y="66" width="80" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="145" y="78" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">6. No Streams</text>

          <rect x="55" y="90" width="90" height="18" rx="3" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="100" y="102" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">7. No Transactions</text>

          <!-- Modify 1 byte example -->
          <text x="100" y="128" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">Change 1 byte of 10 GB?</text>
          <text x="100" y="142" text-anchor="middle" fill="#e74c3c" font-size="8" font-family="var(--font-mono)" font-weight="bold">Re-upload 10 GB.</text>

          <text x="100" y="175" text-anchor="middle" fill="#e74c3c" font-size="10" font-family="var(--font-sans)">Seven Limitations</text>
          <text x="100" y="190" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Frozen since 2006</text>
        </g>

        <!-- Stage 3: ML Mismatch -->
        <g id="s3-stage-3" class="s3-stage">
          <!-- GPU array -->
          <rect x="25" y="15" width="150" height="30" rx="4" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="40" y="33" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">GPU</text>
          <text x="70" y="33" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">GPU</text>
          <text x="100" y="33" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">GPU</text>
          <text x="130" y="33" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">GPU</text>
          <text x="155" y="33" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">...</text>

          <!-- Arrow down: what they need -->
          <text x="100" y="55" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">need: shuffle, stream, prefetch</text>

          <!-- S3 bucket (can't deliver) -->
          <rect x="40" y="62" width="120" height="25" rx="4" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="100" y="78" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">S3: GET one at a time</text>

          <!-- Workarounds -->
          <text x="100" y="100" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6.5" font-family="var(--font-mono)" font-weight="bold">Workarounds everywhere:</text>
          <text x="30" y="114" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">WebDataset (TAR shards)</text>
          <text x="30" y="126" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">MosaicML Streaming</text>
          <text x="30" y="138" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">FFCV (.beton format)</text>
          <text x="30" y="150" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">DeepSeek 3FS (own FS!)</text>

          <text x="100" y="175" text-anchor="middle" fill="#e74c3c" font-size="10" font-family="var(--font-sans)">The ML Mismatch</text>
          <text x="100" y="190" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Designed for images, not training</text>
        </g>

        <!-- Stage 4: Compatibility Trap -->
        <g id="s3-stage-4" class="s3-stage">
          <!-- Lock/chain icon -->
          <rect x="55" y="15" width="90" height="35" rx="4" stroke="#e74c3c" stroke-width="1.5" fill="var(--color-surface-alt)" />
          <text x="100" y="30" text-anchor="middle" fill="#e74c3c" font-size="8" font-family="var(--font-mono)" font-weight="bold">S3 API</text>
          <text x="100" y="43" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">FROZEN</text>

          <!-- Chains connecting to ecosystem -->
          <line x1="55" y1="40" x2="30" y2="65" stroke="#e74c3c" stroke-width="1" />
          <line x1="100" y1="50" x2="100" y2="65" stroke="#e74c3c" stroke-width="1" />
          <line x1="145" y1="40" x2="170" y2="65" stroke="#e74c3c" stroke-width="1" />

          <text x="30" y="75" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">MinIO</text>
          <text x="100" y="75" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Ceph</text>
          <text x="170" y="75" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">R2</text>

          <!-- Cost callout -->
          <rect x="25" y="90" width="150" height="25" rx="3" fill="#e74c3c" fill-opacity="0.08" stroke="#e74c3c" stroke-width="1" />
          <text x="100" y="100" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">17.28M API calls/day/pipeline</text>
          <text x="100" y="111" text-anchor="middle" fill="#e74c3c" font-size="6" font-family="var(--font-mono)">= $1,161/month per pipeline</text>

          <!-- Can't fix it -->
          <text x="100" y="135" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">Can't fix: breaks everything</text>
          <text x="100" y="148" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">Can't leave: everything uses it</text>

          <text x="100" y="178" text-anchor="middle" fill="#e74c3c" font-size="10" font-family="var(--font-sans)">The Compatibility Trap</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">$1.47B market locked in</text>
        </g>

        <!-- Stage 5: What GCS/Azure Got Right -->
        <g id="s3-stage-5" class="s3-stage">
          <!-- Three columns: S3 vs GCS vs Azure -->
          <text x="45" y="20" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)" font-weight="bold">S3</text>
          <text x="100" y="20" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">GCS</text>
          <text x="158" y="20" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">Azure</text>

          <line x1="20" y1="25" x2="185" y2="25" stroke="var(--color-border)" stroke-width="0.5" />

          <!-- Feature comparison -->
          <text x="20" y="38" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">XML only</text>
          <text x="80" y="38" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">JSON + gRPC</text>
          <text x="140" y="38" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">JSON</text>

          <text x="20" y="52" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">No append</text>
          <text x="80" y="52" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Compose</text>
          <text x="140" y="52" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Append Blob</text>

          <text x="20" y="66" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">No partial</text>
          <text x="80" y="66" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">No partial</text>
          <text x="140" y="66" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Page Blob</text>

          <text x="20" y="80" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">No batch</text>
          <text x="80" y="80" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Limited</text>
          <text x="140" y="80" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">256/batch</text>

          <text x="20" y="94" fill="#e74c3c" font-size="5.5" font-family="var(--font-mono)">No project</text>
          <text x="80" y="94" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Field select</text>
          <text x="140" y="94" fill="var(--color-text-tertiary)" font-size="5.5" font-family="var(--font-mono)">Limited</text>

          <!-- Bottom line -->
          <line x1="20" y1="105" x2="185" y2="105" stroke="var(--color-border)" stroke-width="0.5" />
          <text x="100" y="122" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)">Not unsolved problems.</text>
          <text x="100" y="136" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)" font-weight="bold">Solved problems S3 skipped.</text>

          <text x="100" y="175" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)">The Competition</text>
          <text x="100" y="190" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">GCS and Azure shipped what S3 won't</text>
        </g>

        <!-- Stage 6: Escape Attempts -->
        <g id="s3-stage-6" class="s3-stage">
          <!-- S3 planet (gravity well) -->
          <circle cx="100" cy="55" r="30" stroke="var(--color-text-tertiary)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="100" y="52" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="9" font-family="var(--font-mono)" font-weight="bold">S3</text>
          <text x="100" y="64" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="6" font-family="var(--font-mono)">gravity well</text>

          <!-- Orbiting escape attempts -->
          <circle cx="45" cy="20" r="14" stroke="#e74c3c" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="45" y="22" text-anchor="middle" fill="#e74c3c" font-size="5" font-family="var(--font-mono)">CDMI</text>
          <line x1="37" y1="18" x2="53" y2="24" stroke="#e74c3c" stroke-width="1" />

          <circle cx="160" cy="25" r="14" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="160" y="27" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">Iceberg</text>

          <circle cx="30" cy="80" r="14" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="30" y="82" text-anchor="middle" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">LakeFS</text>

          <circle cx="170" cy="80" r="14" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-surface-alt)" />
          <text x="170" y="78" text-anchor="middle" fill="var(--color-accent)" font-size="4.5" font-family="var(--font-mono)">Hugging</text>
          <text x="170" y="86" text-anchor="middle" fill="var(--color-accent)" font-size="4.5" font-family="var(--font-mono)">Face</text>

          <!-- 3FS escaping -->
          <circle cx="100" cy="110" r="14" stroke="var(--color-accent)" stroke-width="1.5" fill="var(--color-surface-alt)" />
          <text x="100" y="112" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)" font-weight="bold">3FS</text>
          <line x1="100" y1="124" x2="100" y2="140" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="100" y="152" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">7.3 TB/s</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="10" font-family="var(--font-sans)">Escape Attempts</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Build on top, or build from scratch</text>
        </g>

        <!-- Stage 7: AWS Sub-APIs -->
        <g id="s3-stage-7" class="s3-stage">
          <!-- Base S3 (frozen) -->
          <rect x="20" y="80" width="160" height="25" rx="4" stroke="var(--color-text-tertiary)" stroke-width="1.5" fill="var(--color-surface-alt)" />
          <text x="100" y="96" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)">S3 Base API (frozen forever)</text>

          <!-- Sub-APIs stacked on top -->
          <rect x="20" y="15" width="50" height="22" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="45" y="29" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Tables</text>

          <rect x="75" y="15" width="50" height="22" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="100" y="29" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">Vectors</text>

          <rect x="130" y="15" width="50" height="22" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="155" y="29" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Express</text>

          <rect x="45" y="44" width="55" height="22" rx="3" stroke="var(--color-accent)" stroke-width="1" fill="var(--color-accent)" fill-opacity="0.08" />
          <text x="72" y="58" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Cond. Writes</text>

          <!-- Arrows from sub-APIs to base -->
          <line x1="45" y1="37" x2="45" y2="80" stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2 2" />
          <line x1="100" y1="37" x2="100" y2="80" stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2 2" />
          <line x1="155" y1="37" x2="155" y2="80" stroke="var(--color-border)" stroke-width="0.5" stroke-dasharray="2 2" />

          <!-- Not really S3 -->
          <text x="100" y="125" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">S3 Tables ≠ S3</text>
          <text x="100" y="138" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">S3 Vectors ≠ S3</text>
          <text x="100" y="151" text-anchor="middle" fill="#e74c3c" font-size="7" font-family="var(--font-mono)">S3 Express ≠ S3</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="10" font-family="var(--font-sans)">AWS Won't Fix S3</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">New products in S3's clothing</text>
        </g>

        <!-- Stage 8: What's Next -->
        <g id="s3-stage-8" class="s3-stage">
          <!-- Next API features -->
          <text x="100" y="18" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-mono)" font-weight="bold">The Next API</text>

          <rect x="20" y="28" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="57" y="39" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">APPEND + PATCH</text>

          <rect x="105" y="28" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="142" y="39" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Batch Atomic</text>

          <rect x="20" y="50" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="57" y="61" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">WATCH stream</text>

          <rect x="105" y="50" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="142" y="61" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">gRPC + JSON</text>

          <rect x="20" y="72" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="57" y="83" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">Filter + Project</text>

          <rect x="105" y="72" width="75" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="1" />
          <text x="142" y="83" text-anchor="middle" fill="var(--color-accent)" font-size="5.5" font-family="var(--font-mono)">PREFETCH hints</text>

          <!-- Plus: backward compatible -->
          <line x1="30" y1="98" x2="170" y2="98" stroke="var(--color-border)" stroke-width="0.5" />
          <rect x="30" y="105" width="140" height="22" rx="4" fill="var(--color-surface-alt)" stroke="var(--color-text-tertiary)" stroke-width="1" />
          <text x="100" y="119" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)">S3 compatible base layer</text>

          <text x="100" y="148" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">Extend, don't replace.</text>

          <text x="100" y="178" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-family="var(--font-sans)" font-weight="600">Beyond S3</text>
          <text x="100" y="193" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">The next battle is what S3 can't do</text>
        </g>
      </svg>
    </div>

    <!-- Metric panel -->
    <div class="mt-4 rounded-lg bg-[var(--color-surface-alt)] px-3 py-2.5 text-center">
      <p class="text-[9px] uppercase tracking-widest text-[var(--color-text-tertiary)]" id="s3-metric-label">API Operations</p>
      <p class="mt-1 font-mono text-lg font-bold text-[var(--color-accent)]">
        <span id="s3-metric-value">5</span>
        <span id="s3-metric-unit" class="text-sm font-normal"></span>
      </p>
      <p id="s3-metric-sub" class="text-[9px] text-[var(--color-text-tertiary)]">PUT GET DELETE HEAD LIST</p>
    </div>

    <!-- Stage dots -->
    <div class="mt-3 flex justify-center gap-1.5">
      <div class="s3-dot active" data-stage="1"></div>
      <div class="s3-dot" data-stage="2"></div>
      <div class="s3-dot" data-stage="3"></div>
      <div class="s3-dot" data-stage="4"></div>
      <div class="s3-dot" data-stage="5"></div>
      <div class="s3-dot" data-stage="6"></div>
      <div class="s3-dot" data-stage="7"></div>
      <div class="s3-dot" data-stage="8"></div>
    </div>

    <!-- ELI10 -->
    <div class="mt-5 rounded-lg border border-[var(--color-border)]/30 bg-[var(--color-surface-alt)]/50 px-3.5 py-3">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
        Explain Like I'm 10
      </p>
      <p id="s3-eli10-text" class="s3-eli10-fade mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)]">
        In 2006, Amazon built a really simple way to store stuff online. Like a locker where you can put things in and take things out. Twenty years later, everyone uses these lockers for everything, even things lockers were never designed for.
      </p>
    </div>
  </div>
</aside>

<style>
  .s3-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .s3-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .s3-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .s3-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .s3-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .s3-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .s3-eli10-fade {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .s3-eli10-fade.changing {
    opacity: 0;
    transform: translateY(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .s3-stage { transition: none; }
    .s3-dot { transition: none; }
    .s3-eli10-fade { transition: none; }
  }
</style>

<script>
  function initS3Evolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("accidental standard")) stage = 1;
      else if (text.includes("seven limitations")) stage = 2;
      else if (text.includes("no append")) stage = 2;
      else if (text.includes("no partial")) stage = 2;
      else if (text.includes("list is a full")) stage = 2;
      else if (text.includes("server-side compute")) stage = 2;
      else if (text.includes("xml in")) stage = 2;
      else if (text.includes("real-time change")) stage = 2;
      else if (text.includes("multi-object transaction")) stage = 2;
      else if (text.includes("ml actually needs")) stage = 3;
      else if (text.includes("shuffle problem")) stage = 3;
      else if (text.includes("fan-out problem")) stage = 3;
      else if (text.includes("checkpoint problem")) stage = 3;
      else if (text.includes("kv cache problem")) stage = 3;
      else if (text.includes("compatibility trap")) stage = 4;
      else if (text.includes("ecosystem is the moat")) stage = 4;
      else if (text.includes("lcd effect")) stage = 4;
      else if (text.includes("cost of chatty")) stage = 4;
      else if (text.includes("gcs and azure")) stage = 5;
      else if (text.includes("from gcs")) stage = 5;
      else if (text.includes("from azure")) stage = 5;
      else if (text.includes("attempts to escape")) stage = 6;
      else if (text.includes("cdmi")) stage = 6;
      else if (text.includes("iceberg rest")) stage = 6;
      else if (text.includes("lakefs")) stage = 6;
      else if (text.includes("hugging face hub")) stage = 6;
      else if (text.includes("deepseek 3fs")) stage = 6;
      else if (text.includes("aws is actually")) stage = 7;
      else if (text.includes("credit where")) stage = 7;
      else if (text.includes("minio saw")) stage = 7;
      else if (text.includes("next storage api")) stage = 8;
      else if (text.includes("pragmatic path")) stage = 8;
      else if (text.includes("api is the ceiling")) stage = 8;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".s3-stage");
    const dots = document.querySelectorAll(".s3-dot");
    const metricLabel = document.getElementById("s3-metric-label");
    const metricValue = document.getElementById("s3-metric-value");
    const metricUnit = document.getElementById("s3-metric-unit");
    const metricSub = document.getElementById("s3-metric-sub");

    const metricData = [
      { label: "API Operations", value: "5", unit: "", sub: "PUT GET DELETE HEAD LIST" },
      { label: "Max LIST Page", value: "1,000", unit: " keys", sub: "paginated XML, no filtering" },
      { label: "Checkpoint Cost", value: "$83", unit: "", sub: "per pause at 1K GPUs" },
      { label: "API Cost", value: "$1,161", unit: "/mo", sub: "per streaming pipeline" },
      { label: "GCS gRPC Gain", value: "107%", unit: "", sub: "higher throughput vs REST" },
      { label: "3FS Throughput", value: "7.3", unit: " TB/s", sub: "DeepSeek escaped S3" },
      { label: "Conditional Writes", value: "18", unit: " yrs late", sub: "single-object only" },
      { label: "New Primitives", value: "8", unit: "", sub: "what S3 v2 needs" },
    ];

    const eli10El = document.getElementById("s3-eli10-text");
    const eli10Data = [
      "In 2006, Amazon built a really simple way to store stuff online. Like a locker where you can put things in and take things out. Twenty years later, everyone uses these lockers for everything, even things lockers were never designed for.",
      "Imagine a notebook where you can only write full pages. Want to fix one word? Rip out the whole page and rewrite it. Want to find something? Read every single page from the beginning. That's S3.",
      "Training an AI is like shuffling a deck of 10 million cards and looking at each one. But with S3, every time you pick a card, you have to walk to the library, ask the librarian, wait in line, and walk back. For every. single. card.",
      "S3 is like a really popular playground. Everyone learned how to use it. All the games are designed for it. But the slide is broken, the swings are too slow, and nobody can fix anything because changing the playground would confuse all the kids who already know how it works.",
      "Google and Microsoft built better playgrounds with faster slides, working swings, and a snack bar. Amazon's playground is still more popular because everyone's friends are already there. Sometimes being first matters more than being best.",
      "Some kids got so frustrated with the playground they built their own in the backyard. DeepSeek built a super-fast one. Hugging Face built one just for robot toys. LakeFS added a save button so you can undo mistakes. All because the original playground is missing stuff.",
      "Instead of fixing the old playground, Amazon keeps building tiny new playgrounds next to it and calling them all by the same name. \"S3 Tables\" isn't really S3. \"S3 Vectors\" isn't really S3. It's like calling every building in town \"the school.\"",
      "The dream is a storage system that speaks S3 so all the old tools work, but also has an express lane for new stuff. Like a library that still has a card catalog for grandma, but also has a search engine for everyone else.",
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }

      if (eli10El && eli10Data[stage - 1]) {
        eli10El.classList.add("changing");
        setTimeout(() => {
          eli10El.textContent = eli10Data[stage - 1];
          eli10El.classList.remove("changing");
        }, 200);
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initS3Evolution();
</script>
