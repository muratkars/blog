---
interface Props {
  title?: string;
}

const { title = "Terminal" } = Astro.props;
---

<div class="terminal-window my-6 overflow-hidden rounded-xl border border-[var(--color-border)]/50 bg-[#1e1e1e] shadow-lg">
  <div class="flex items-center gap-2 border-b border-white/10 bg-[#2d2d2d] px-4 py-2.5">
    <div class="flex gap-1.5">
      <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
    </div>
    <span class="flex-1 text-center text-xs font-medium text-white/50">{title}</span>
    <button
      class="terminal-copy flex items-center justify-center w-7 h-7 rounded-md text-white/40 hover:text-white/80 hover:bg-white/10 transition-colors"
      aria-label="Copy to clipboard"
    >
      <svg class="copy-icon w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9.75a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184" />
      </svg>
      <svg class="check-icon hidden w-4 h-4 text-[#28c840]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
    </button>
  </div>
  <div class="terminal-body [&_pre]:!my-0 [&_pre]:!rounded-none [&_pre]:!border-0 [&_pre]:!bg-transparent [&_pre]:!shadow-none">
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll('.terminal-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const window = btn.closest('.terminal-window');
      const code = window?.querySelector('pre code');
      if (!code) return;

      navigator.clipboard.writeText(code.textContent || '').then(() => {
        const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      });
    });
  });
</script>
