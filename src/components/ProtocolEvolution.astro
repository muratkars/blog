          <text x="91" y="125" text-anchor="middle" fill="var(--color-accent)" font-size="6" font-family="var(--font-mono)">time travel</text>
          <rect x="121" y="115" width="54" height="14" rx="7" fill="var(--color-accent)" opacity="0.1" stroke="var(--color-accent)" stroke-width="0.5" />
