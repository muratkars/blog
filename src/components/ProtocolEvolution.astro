          <text x="100" y="51" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">G1: HBM</text>
          <text x="165" y="51" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">ns</text>

          <rect x="40" y="60" width="120" height="16" rx="3" fill="var(--color-accent)" opacity="0.12" stroke="var(--color-accent)" stroke-width="0.5" />
          <text x="100" y="71" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">G2: Host RAM</text>
          <text x="165" y="71" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">us</text>

          <rect x="40" y="80" width="120" height="16" rx="3" fill="var(--color-accent)" opacity="0.08" stroke="var(--color-accent)" stroke-width="0.5" />
          <text x="100" y="91" text-anchor="middle" fill="var(--color-accent)" font-size="7" font-family="var(--font-mono)">G3: NVMe</text>
          <text x="165" y="91" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">100us</text>

          <!-- CMX highlighted with pulse -->
          <rect x="35" y="100" width="130" height="20" rx="4" fill="var(--color-accent)" opacity="0.1" stroke="var(--color-accent)" stroke-width="2" />
          <text x="100" y="113" text-anchor="middle" fill="var(--color-accent)" font-size="8" font-family="var(--font-mono)" font-weight="bold">G3.5: CMX</text>
          <text x="170" y="113" fill="var(--color-accent)" font-size="5" font-family="var(--font-mono)">RDMA</text>
          <rect x="35" y="100" width="130" height="20" rx="4" fill="none" stroke="var(--color-accent)" stroke-width="1" class="cmx-pulse" />

          <rect x="40" y="124" width="120" height="16" rx="3" fill="var(--color-surface-alt)" stroke="var(--color-border)" stroke-width="0.75" />
          <text x="100" y="135" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="7" font-family="var(--font-mono)">G4: Object Storage</text>
          <text x="165" y="135" fill="var(--color-text-tertiary)" font-size="5" font-family="var(--font-mono)">ms</text>

          <text x="100" y="160" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="10" font-family="var(--font-sans)">AI Memory Hierarchy</text>
          <text x="100" y="175" text-anchor="middle" fill="var(--color-text-tertiary)" font-size="8" font-family="var(--font-sans)" opacity="0.7">Context Memory eXtensions</text>
        </g>
      </svg>
    </div>

    <!-- Speed/capacity indicator -->
    <div class="mt-4 rounded-lg bg-[var(--color-surface-alt)] px-3 py-2.5 text-center">
      <p class="text-[9px] uppercase tracking-widest text-[var(--color-text-tertiary)]" id="proto-metric-label">Drive Throughput</p>
      <p class="mt-1 font-mono text-lg font-bold text-[var(--color-accent)]">
        <span id="proto-metric-value">200</span>
        <span id="proto-metric-unit" class="text-sm font-normal"> MB/s</span>
      </p>
      <p id="proto-metric-sub" class="text-[9px] text-[var(--color-text-tertiary)]">Sequential read</p>
