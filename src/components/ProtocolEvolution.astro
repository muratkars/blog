    <!-- Stage dots -->
    <div class="mt-3 flex justify-center gap-1">
      <div class="proto-dot active" data-stage="1"></div>
      <div class="proto-dot" data-stage="2"></div>
      <div class="proto-dot" data-stage="3"></div>
      <div class="proto-dot" data-stage="4"></div>
      <div class="proto-dot" data-stage="5"></div>
      <div class="proto-dot" data-stage="6"></div>
      <div class="proto-dot" data-stage="7"></div>
      <div class="proto-dot" data-stage="8"></div>
      <div class="proto-dot" data-stage="9"></div>
      <div class="proto-dot" data-stage="10"></div>
    </div>

    <!-- ELI10 -->
    <div class="mt-5 rounded-lg border border-[var(--color-border)]/30 bg-[var(--color-surface-alt)]/50 px-3.5 py-3">
      <p class="text-[9px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
        Explain Like I'm 10
      </p>
      <p id="eli10-text" class="mt-2 text-xs leading-relaxed text-[var(--color-text-secondary)] eli10-fade">
        Your computer needs a place to keep its files. A storage protocol is the language it uses to ask for them. Like how you ask your mom where your backpack is, but for data.
      </p>
