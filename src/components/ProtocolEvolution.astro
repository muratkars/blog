</aside>

<style>
  .proto-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .proto-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .proto-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .proto-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .proto-dot.active {
    background: var(--color-accent);
    transform: scale(1.5);
  }

  .proto-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .data-flow-up {
    animation: flowUp 1.5s ease-in-out infinite;
  }

  @keyframes flowUp {
    0% { opacity: 0; transform: translateY(8px); }
    50% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-8px); }
  }

  .spin-hint {
    animation: spinHint 2s ease-in-out infinite;
  }

  @keyframes spinHint {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  .cmx-pulse {
    animation: cmxPulse 2s ease-in-out infinite;
  }

  @keyframes cmxPulse {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.5; }
  }

  .eli10-fade {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .eli10-fade.changing {
    opacity: 0;
    transform: translateY(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .proto-stage { transition: none; }
    .proto-dot { transition: none; }
    .data-flow-up, .spin-hint, .cmx-pulse { animation: none; }
    .eli10-fade { transition: none; }
  }
</style>

<script>
  function initProtocolEvolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("what is") && text.includes("storage protocol")) stage = 1;
      else if (text.includes("hard disk")) stage = 1;
      else if (text.includes("solid state") || text.includes("ssd") && text.includes("sata")) stage = 2;
      else if (text.includes("nvme ssd") || text.includes("game changer")) stage = 3;
      else if (text.includes("layer 1")) stage = 1;
      else if (text.includes("direct-attached") || text.includes("layer 2")) stage = 4;
      else if (text.includes("network-attached") || text.includes("nas") && text.includes("nfs")) stage = 5;
      else if (text.includes("block storage") || text.includes("layer 3")) stage = 6;
      else if (text.includes("rise of the san")) stage = 6;
      else if (text.includes("san drama")) stage = 6;
      else if (text.includes("nvme over") || text.includes("san reborn") || text.includes("layer 4")) stage = 7;
      else if (text.includes("nvme-of exists")) stage = 7;
      else if (text.includes("transport option")) stage = 7;
      else if (text.includes("promise vs")) stage = 7;
      else if (text.includes("object storage") && (text.includes("layer 5") || text.includes("quiet"))) stage = 8;
      else if (text.includes("what object storage")) stage = 8;
      else if (text.includes("origin story")) stage = 8;
      else if (text.includes("slow") && text.includes("reputation")) stage = 8;
      else if (text.includes("transformation")) stage = 8;
      else if (text.includes("why object storage")) stage = 8;
      else if (text.includes("data lake") || text.includes("layer 6")) stage = 9;
      else if (text.includes("lakehouse")) stage = 9;
      else if (text.includes("nvidia factor")) stage = 10;
      else if (text.includes("current state")) stage = 10;
      else if (text.includes("shift") && text.includes("object storage is coming")) stage = 10;
      else if (text.includes("context memory") || text.includes("icms") || text.includes("cmx")) stage = 10;
      else if (text.includes("putting it all")) stage = 10;
      else if (text.includes("trajectory")) stage = 10;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".proto-stage");
    const dots = document.querySelectorAll(".proto-dot");
    const metricLabel = document.getElementById("proto-metric-label");
    const metricValue = document.getElementById("proto-metric-value");
    const metricUnit = document.getElementById("proto-metric-unit");
    const metricSub = document.getElementById("proto-metric-sub");

    const metricData = [
      { label: "Drive Throughput", value: "200", unit: " MB/s", sub: "HDD sequential read" },
      { label: "Drive Throughput", value: "600", unit: " MB/s", sub: "SATA ceiling" },
      { label: "Drive Throughput", value: "14", unit: " GB/s", sub: "PCIe Gen5 x4" },
      { label: "Aggregate BW", value: "168", unit: " GB/s", sub: "24x NVMe DAS" },
      { label: "Access Latency", value: "~1", unit: " ms", sub: "NFS over Ethernet" },
      { label: "Access Latency", value: "<1", unit: " ms", sub: "FC SAN block I/O" },
      { label: "Added Latency", value: "5-80", unit: " us", sub: "RDMA to TCP range" },
      { label: "Durability", value: "11", unit: " nines", sub: "99.999999999%" },
      { label: "Query Speedup", value: "3x", unit: "", sub: "Iceberg vs self-managed" },
      { label: "Inference Boost", value: "5x", unit: "", sub: "tokens/sec with CMX" },
    ];

    const eli10El = document.getElementById("eli10-text");
    const eli10Data = [
      "Your computer needs a place to keep its files. A storage protocol is the language it uses to ask for them. Like how you ask your mom where your backpack is, but for data.",
      "Hard drives have a spinning metal disc and a tiny arm that reads it. Like a record player, but for your homework. They're slow because the arm has to physically move to find stuff.",
      "SSDs are like a really organized notebook where you can flip to any page instantly. No spinning, no waiting. But the old connector (SATA) is like a narrow doorway that makes everyone wait in line.",
      "NVMe is what happens when you give the SSD its own private highway instead of sharing the old road. Same notebook, way wider doorway. A single NVMe drive is faster than a whole room of hard drives.",
      "DAS is an extension cord for your drives. They're in a separate box but plugged directly into your computer. Simple, fast, no sharing. Like having your own cubby instead of a shared locker.",
      "NAS is like a shared Google Drive but on your home network. Everyone can access the same files. The problem? When 1,000 people ask \"where's my file?\" at the same time, the librarian melts down.",
      "A SAN is a private road built just for storage traffic. Super fast, super expensive. Like building your own highway because the regular roads are too crowded. The cloud killed most of them.",
      "NVMe-oF makes faraway drives feel close. It's like having really long arms that can reach drives on the other side of the room almost as fast as the ones right next to you.",
      "Object storage is the simplest idea ever: give your file a name, throw it in a giant bucket, ask for it by name later. No folders, no organizing. Like tossing toys in a huge bin with labels. It scales to infinity.",
      "A data lakehouse puts labels and rules on your giant bucket. And NVIDIA built a special shelf (CMX) between the GPU's brain and the bucket so it doesn't have to keep walking back and forth to get things.",
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }

      if (eli10El && eli10Data[stage - 1]) {
        eli10El.classList.add("changing");
        setTimeout(() => {
          eli10El.textContent = eli10Data[stage - 1];
          eli10El.classList.remove("changing");
        }, 200);
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initProtocolEvolution();
</script>
