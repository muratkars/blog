<style>
  .posix-stage {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .posix-stage.active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .posix-stage.past {
    opacity: 0;
    transform: translateY(-12px);
  }

  .posix-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border);
    transition: background 0.3s, transform 0.3s;
  }

  .posix-dot.active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  .posix-dot.past {
    background: var(--color-accent);
    opacity: 0.4;
  }

  .stress-pulse {
    animation: stressPulse 1s ease-in-out infinite;
  }

  @keyframes stressPulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.8; }
  }

  .qubit-orbit {
    animation: qubitSpin 4s linear infinite;
    transform-origin: 100px 40px;
  }

  @keyframes qubitSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .qubit-dot {
    animation: qubitPulse 1.5s ease-in-out infinite;
  }

  @keyframes qubitPulse {
    0%, 100% { opacity: 0.2; r: 2; }
    50% { opacity: 0.8; r: 3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .posix-stage { transition: none; }
    .posix-dot { transition: none; }
    .stress-pulse, .qubit-orbit, .qubit-dot { animation: none; }
  }
</style>

<script>
  function initPosixEvolution() {
    const prose = document.querySelector(".prose");
    if (!prose) return;

    const allHeadings = prose.querySelectorAll("h2, h3");
    if (allHeadings.length === 0) return;

    const stageMap: { el: Element; stage: number }[] = [];

    allHeadings.forEach((h) => {
      const text = (h.textContent || "").toLowerCase();
      let stage = -1;

      if (text.includes("where posix came from")) stage = 1;
      else if (text.includes("six sins")) stage = 2;
      else if (text.includes("metadata wall")) stage = 2;
      else if (text.includes("statefulness")) stage = 3;
      else if (text.includes("locking nightmare")) stage = 4;
      else if (text.includes("consistency trap")) stage = 5;
      else if (text.includes("hierarchy illusion")) stage = 5;
      else if (text.includes("syscall overhead")) stage = 5;
      else if (text.includes("gateway trap")) stage = 6;
      else if (text.includes("quantum")) stage = 7;
      else if (text.includes("quantum storage")) stage = 7;
      else if (text.includes("actually impacts")) stage = 7;
      else if (text.includes("way forward")) stage = 8;
      else if (text.includes("s3 api")) stage = 8;
      else if (text.includes("data-aware")) stage = 8;
      else if (text.includes("post-quantum security")) stage = 8;
      else if (text.includes("no metadata server")) stage = 8;
      else if (text.includes("conclusion")) stage = 8;

      if (stage > 0) {
        stageMap.push({ el: h, stage });
      }
    });

    if (stageMap.length === 0) return;

    let currentStage = 1;

    const stages = document.querySelectorAll(".posix-stage");
    const dots = document.querySelectorAll(".posix-dot");
    const metricLabel = document.getElementById("posix-metric-label");
    const metricValue = document.getElementById("posix-metric-value");
    const metricUnit = document.getElementById("posix-metric-unit");
    const metricSub = document.getElementById("posix-metric-sub");

    const metricData = [
      { label: "Year Designed", value: "1988", unit: "", sub: "IEEE Std 1003.1" },
      { label: "MDS Bottleneck", value: "M+", unit: " ops/min", sub: "14M files = MDS meltdown" },
      { label: "Kernel State", value: "100M", unit: "", sub: "file descriptors across cluster" },
      { label: "Reliable Locks", value: "0", unit: "", sub: "on network filesystems" },
      { label: "Wasted Overhead", value: "4+", unit: " syscalls", sub: "per file, millions of files" },
      { label: "Translation Cost", value: "10-100", unit: "x", sub: "latency penalty vs native" },
      { label: "CRQC Timeline", value: "2030s", unit: "", sub: "post-quantum migration needed" },
      { label: "API Calls", value: "1", unit: "", sub: "HTTP request per operation" },
    ];

    function setStage(stage: number) {
      if (stage === currentStage) return;
      currentStage = stage;

      stages.forEach((s, i) => {
        const stageNum = i + 1;
        s.classList.remove("active", "past");
        if (stageNum === stage) s.classList.add("active");
        else if (stageNum < stage) s.classList.add("past");
      });

      dots.forEach((d, i) => {
        const dotStage = i + 1;
        d.classList.remove("active", "past");
        if (dotStage === stage) d.classList.add("active");
        else if (dotStage < stage) d.classList.add("past");
      });

      const data = metricData[stage - 1];
      if (data && metricLabel && metricValue && metricUnit && metricSub) {
        metricLabel.textContent = data.label;
        metricValue.textContent = data.value;
        metricUnit.textContent = data.unit;
        metricSub.textContent = data.sub;
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const match = stageMap.find((s) => s.el === entry.target);
          if (match) setStage(match.stage);
        }
      });
    }, { rootMargin: "-15% 0px -75% 0px" });

    stageMap.forEach(({ el }) => observer.observe(el));
    setStage(1);
  }

  initPosixEvolution();
</script>
